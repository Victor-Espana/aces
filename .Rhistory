# Basic test for tune_model()
library(aces)
# Simulate simple production data
data <- cobb_douglas_XnY1 (
N = 100,
nX = 6
)
x <- 1:6
y <- 7
# Test 1: Basic ACES tuning with a small grid
cat("=== Test 1: Basic ACES tuning ===\n")
grid <- expand.grid (
max_degree = 3,
inter_cost = c(0.1, 0.05, 0.01),
metric = "mae",
err_red = 0.05,
kn_penalty = c(1, 2)
)
print(grid)
grid <- expand.grid (
max_degree = 3,
inter_cost = c(0.1, 0.05, 0.01),
metric = "mae",
err_red = 0.05,
kn_penalty = c(1, 2)
)
print(grid)
tuned <- tune_model(
data       = data,
x          = 1:2,
y          = 3,
model      = "aces",
grid       = grid,
metric     = "mae",
validation = "kfold",
folds      = 5,
delta      = 1.10,
seed       = 42,
verbose    = TRUE
)
