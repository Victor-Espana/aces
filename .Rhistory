test_that("tune_model_aces tunes a complex simulated frontier", {
data <- simulate_production_data(2026)
partition <- data_partition_aces(
data = data,
x = paste0("x", 1:6),
y = "y",
validation = "holdout",
repeats = 2,
train_prop = 0.8,
seed = 2026
)
invisible(capture.output(
tuned <- tune_model_aces(
partition = partition,
quick_aces = TRUE,
max_degree = c(1, 2),
inter_cost = c(0.01, 0.05),
max_terms = 20,
err_red = c(0.01, 0.05),
kn_penalty = 2,
validation_metric = "rmse",
delta = 1.5,
seed = 2026,
verbose = FALSE
)
))
expect_equal(nrow(data), 100)
expect_s3_class(partition, "aces_partition")
expect_s3_class(tuned, "aces_tune")
expect_s3_class(tuned$final_model, "aces")
expect_equal(nrow(tuned$results), 8)
expect_true(is.finite(tuned$best_score))
expect_true(all(is.finite(tuned$results$mean_score)))
expect_named(
tuned$best_params,
c(
"scale_data", "quick_aces", "max_degree", "inter_cost", "metric",
"mono", "conc", "max_terms", "err_red", "kn_grid", "minspan",
"endspan", "kn_penalty"
)
)
})
