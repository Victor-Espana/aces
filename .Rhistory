simulate_production_data <- function(seed) {
set.seed(seed)
cobb_douglas_XnY1(N = 100, nX = 3)
}
data <- simulate_production_data(2026)
partition <- data_partition(
data = data,
x = 1:3,
y = 4,
validation = "holdout",
resampling_args = list(repeats = 1, train_prop = 0.8),
delta = 1.25,
seed = 2026
)
invisible(capture.output(
tuned <- tune_model_aces(
partition = partition,
mul_BF = list(
max_degree = c(2),
inter_cost = c(0.01, 0.05)
),
metric = "mae",
err_red = c(0.01, 0.05),
kn_penalty = c(1, 2),
validation_metric = c("rmse", "mae"),
verbose = TRUE
)
))
View(tuned)
tuned[["final_model"]]
tuned[["results"]]
tuned[["best_params"]]
devtools::load_all()
invisible(capture.output(
