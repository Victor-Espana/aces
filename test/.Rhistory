set.seed(2206261821/ 2)
df <- data.frame (
prio = c(1,4,3,2,5,6),
deso = c(0,-1,1,3,2,2),
time = c(10.4,4,3.4,1.7,0.05,0.05)
)
max_devt <- max(df$deso)
# PRIORITY
df$prio_inv <- 1 / df$prio
df$prio_zst <- (df$prio_inv - mean(df$prio_inv)) / sd(df$prio_inv)
df$prio_nor <- 1 / (1 + exp(- 2 * df$prio_zst))
# DISORDER
df$deso_adj <- df$deso - min(df$deso)
df$deso_zst <- (df$deso_adj - mean(df$deso_adj)) / sd(df$deso_adj)
df$deso_nor <- 1 / (1 + exp(- 2 * df$deso_zst))
# TIME
df$time_inv <- 1 / df$time
df$time_zst <- (df$time_inv - mean(df$time_inv)) / sd(df$time_inv)
df$time_nor <- 1 / (1 + exp(- 2 * df$time_zst))
# SCORE
df$score <- (df$prio_nor + df$deso_nor + df$time_nor) / 3
# PROBABILITY
