# RANDOM CHOICE
selected_task <- df[sample(1:nrow(df), size = max_devt + 1, prob = df$prob), ]
print("Selected task:")
print(selected_task[selected_task$deso >= 0, 1])
setwd("C:/Users/vjespana/Desktop/uni/R packages/aces/test")
PARTIAL_DIR <- file.path("C:/Users/vjespana/Desktop/uni/R packages/aces/test")               # CSV parciales (uno por escenario)
files <- list.files(PARTIAL_DIR, pattern = "^scenario_.*\\.csv$", full.names = TRUE)
if (length(files) == 0) stop("No hay CSV parciales en ", PARTIAL_DIR)
res <- do.call(rbind, lapply(files, read.csv, stringsAsFactors = FALSE))
View(res)
res <- res[order(res$id), ]
rownames(res) <- NULL
if (requireNamespace("writexl", quietly = TRUE)) {
writexl::write_xlsx(res, OUT_XLSX)
} else if (requireNamespace("openxlsx", quietly = TRUE)) {
openxlsx::write.xlsx(res, OUT_XLSX)
} else {
stop("Instala el paquete 'writexl' u 'openxlsx' para generar el xlsx.")
}
